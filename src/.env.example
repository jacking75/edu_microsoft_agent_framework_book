# =============================================================
# Microsoft Agent Framework Book - 환경 변수 설정
# =============================================================
# 이 파일을 .env로 복사하고 실제 값을 입력한다.
#   cp .env.example .env  (또는 복사 후 이름 변경)
# =============================================================

# ── OpenRouter 사용 시 (기본값) ───────────────────────────────
LLM_API_KEY=sk-or-v1-여기에_OpenRouter_API_키를_입력하세요
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4-5

# ── Poe 사용 시 (위 3줄을 아래로 교체) ─────────────────────────
# LLM_API_KEY=여기에_Poe_API_키를_입력하세요
# LLM_BASE_URL=https://api.poe.com/llm/v1
# LLM_MODEL=claude-sonnet-4-20250514

# ── 로컬 Ollama 사용 시 (API 키 불필요) ─────────────────────────
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# =============================================================
# 모델 선택 가이드 (OpenRouter 기준)
# =============================================================
# 빠르고 저렴:    anthropic/claude-haiku-4-5
# 균형 (권장):    anthropic/claude-sonnet-4-5
# 최고 성능:      anthropic/claude-opus-4
# OpenAI 계열:    openai/gpt-4o, openai/gpt-4o-mini
# 저비용:         google/gemini-flash-1.5
# =============================================================
